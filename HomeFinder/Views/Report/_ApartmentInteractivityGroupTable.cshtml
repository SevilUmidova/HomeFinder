@model List<HomeFinder.Models.Reports.ApartmentInteractivityReportVm.GroupRow>
@using System.Globalization

@{
    var inv = CultureInfo.InvariantCulture;
    string pct(double v) => (v * 100).ToString("0.##", inv) + "%";
}

@if (Model == null || Model.Count == 0)
{
    <div class="text-muted">Нет данных.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm mb-0">
            <thead>
                <tr>
                    <th>Группа</th>
                    <th class="text-end">Квартир</th>
                    <th class="text-end">Просмотры</th>
                    <th class="text-end">Обращения</th>
                    <th class="text-end">Конверсия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Take(10))
            {
                <tr>
                    <td>@r.Key</td>
                    <td class="text-end">@r.ApartmentsCount</td>
                    <td class="text-end">@r.Views</td>
                    <td class="text-end">@r.Inquiries</td>
                    <td class="text-end fw-semibold">@pct(r.ConversionRate)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

